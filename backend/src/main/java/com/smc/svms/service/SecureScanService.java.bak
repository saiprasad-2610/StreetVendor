package com.smc.svms.service;

import com.smc.svms.dto.ScanRequest;
import com.smc.svms.dto.ScanValidationResponse;
import com.smc.svms.dto.ValidationResult;
import com.smc.svms.entity.Vendor;
import com.smc.svms.enums.ValidationStatus;
import com.smc.svms.repository.VendorRepository;
import lombok.Builder;
import lombok.Data;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
// MockMultipartFile removed - use MultipartFile interface directly
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.web.multipart.MultipartFile;

import javax.imageio.ImageIO;
import java.awt.image.BufferedImage;
import java.io.ByteArrayInputStream;
import java.io.IOException;
import java.math.BigDecimal;
import java.time.LocalDateTime;
import java.util.Base64;
import java.util.UUID;

/**
 * Secure Scan Service with comprehensive fraud detection
 * Mandatory photo capture with multiple validation layers
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class SecureScanService implements ScanService {

    private final VendorRepository vendorRepository;
    private final ChallanService challanService;
    private final OptimizedScanService optimizedScanService;

    @Value("${app.location.threshold-meters}")
    private double baseThresholdMeters;

    @Override
    @Transactional
    public ScanValidationResponse validateVendorLocation(ScanRequest request) {
        // This method should not be used - always require photo
        throw new UnsupportedOperationException("Photo capture is mandatory. Use validateVendorLocationWithPhoto instead.");
    }

    /**
     * Validate vendor location with mandatory photo and fraud detection
     */
    @Transactional
    public ScanValidationResponse validateVendorLocationWithPhoto(
            String vendorId, double latitude, double longitude, 
            Double gpsAccuracy, String deviceId, String weatherCondition,
            MultipartFile image) {
        
        log.info("Secure validation for vendor {} with photo upload", vendorId);

        // Step 1: Validate image authenticity
        ValidationResult imageValidation = validateImageAuthenticity(image);
        if (!imageValidation.isValid()) {
            log.warn("Fraud detected for vendor {}: {}", vendorId, imageValidation.getErrorMessage());
            throw new SecurityException("FRAUD DETECTED: " + imageValidation.getErrorMessage());
        }

        // Step 2: Extract and validate metadata from image
        ImageMetadata metadata = extractImageMetadata(image);
        ValidationResult metadataValidation = validateImageMetadata(metadata, latitude, longitude);
        if (!metadataValidation.isValid()) {
            log.warn("Metadata validation failed for vendor {}: {}", vendorId, metadataValidation.getErrorMessage());
            throw new SecurityException("FRAUD DETECTED: " + metadataValidation.getErrorMessage());
        }

        // Step 3: Perform location validation using optimized service
        ScanRequest scanRequest = new ScanRequest();
        scanRequest.setVendorId(vendorId);
        scanRequest.setLatitude(latitude);
        scanRequest.setLongitude(longitude);
        scanRequest.setGpsAccuracy(gpsAccuracy);
        scanRequest.setDeviceId(deviceId);
        scanRequest.setWeatherCondition(weatherCondition);
        scanRequest.setImageProofUrl("secure_scan_" + vendorId + "_" + System.currentTimeMillis() + ".jpg");

        ScanValidationResponse response = optimizedScanService.validateVendorLocation(scanRequest);

        // Step 4: Create new response with security metadata
        return ScanValidationResponse.builder()
                .vendorId(response.getVendorId())
                .vendorName(response.getVendorName())
                .category(response.getCategory())
                .validationStatus(response.getValidationStatus())
                .distance(response.getDistance())
                .message(response.getMessage() + " [✅ Photo Verified]")
                .build();
    }

    /**
     * Comprehensive image authenticity validation
     */
    public ValidationResult validateImageAuthenticity(MultipartFile image) {
        try {
            // Check 1: File format and basic properties
            if (!isValidImageFormat(image)) {
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("Invalid image format. Only JPEG/PNG from camera allowed.")
                    .build();
            }

            // Check 2: File size (camera photos are typically larger)
            if (image.getSize() < 50000) { // Less than 50KB
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("Image too small. Real camera capture required.")
                    .build();
            }

            // Check 3: Image dimensions (real camera has standard dimensions)
            BufferedImage bufferedImage = ImageIO.read(image.getInputStream());
            if (bufferedImage.getWidth() < 640 || bufferedImage.getHeight() < 480) {
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("Invalid image dimensions. Real camera resolution required.")
                    .build();
            }

            // Check 4: EXIF data presence
            if (!hasExifData(image)) {
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("No camera metadata detected. Real camera capture required.")
                    .build();
            }

            // Check 5: Watermark verification
            if (!hasRequiredWatermark(bufferedImage)) {
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("Missing or invalid security watermark. Real-time capture required.")
                    .build();
            }

            // Check 6: Hidden metadata verification
            if (!hasHiddenMetadata(image)) {
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("Missing embedded security metadata. Tampered image detected.")
                    .build();
            }

            return ValidationResult.builder().valid(true).build();

        } catch (Exception e) {
            log.error("Error validating image authenticity", e);
            return ValidationResult.builder()
                .valid(false)
                .errorMessage("Image validation failed. Possible tampering detected.")
                .build();
        }
    }

    /**
     * Check if image format is valid
     */
    private boolean isValidImageFormat(MultipartFile image) {
        String contentType = image.getContentType();
        return contentType != null && 
               (contentType.equals("image/jpeg") || contentType.equals("image/jpg") || 
                contentType.equals("image/png"));
    }

    /**
     * Check if image has EXIF data (camera metadata)
     */
    private boolean hasExifData(MultipartFile image) {
        try {
            byte[] imageBytes = image.getBytes();
            String imageString = new String(imageBytes);
            
            // Look for EXIF markers
            String[] exifMarkers = {"Exif", "JFIF", "Camera", "Canon", "Nikon", "Sony", "Samsung"};
            return java.util.Arrays.stream(exifMarkers)
                    .anyMatch(marker -> imageString.contains(marker));
        } catch (Exception e) {
            log.error("Error checking EXIF data", e);
            return false;
        }
    }

    /**
     * Check if image has required security watermark
     */
    private boolean hasRequiredWatermark(BufferedImage image) {
        try {
            // Check bottom 30% for watermark
            int watermarkHeight = (int) (image.getHeight() * 0.3);
            int startY = image.getHeight() - watermarkHeight;
            
            // Look for gold color pixels (watermark color)
            for (int y = startY; y < image.getHeight(); y++) {
                for (int x = 0; x < image.getWidth(); x++) {
                    int pixel = image.getRGB(x, y);
                    int red = (pixel >> 16) & 0xFF;
                    int green = (pixel >> 8) & 0xFF;
                    int blue = pixel & 0xFF;
                    
                    // Check for gold/yellow color (watermark)
                    if (red > 200 && green > 180 && blue < 100) {
                        return true;
                    }
                }
            }
            
            return false;
        } catch (Exception e) {
            log.error("Error checking watermark", e);
            return false;
        }
    }

    /**
     * Check if image has hidden metadata embedded
     */
    private boolean hasHiddenMetadata(MultipartFile image) {
        try {
            byte[] imageBytes = image.getBytes();
            
            // Look for embedded metadata patterns
            String imageString = new String(imageBytes);
            return imageString.contains("SECURITY_TOKEN") &&
                   imageString.contains("SOLAPUR MUNICIPAL CORPORATION") &&
                   imageString.contains("LIVE VERIFICATION");
        } catch (Exception e) {
            log.error("Error checking hidden metadata", e);
            return false;
        }
    }

    /**
     * Extract metadata from image
     */
    private ImageMetadata extractImageMetadata(MultipartFile image) {
        try {
            byte[] imageBytes = image.getBytes();
            String imageString = new String(imageBytes);
            
            // Extract security token
            String token = extractSecurityToken(imageString);
            
            // Extract coordinates from watermark
            String[] coordParts = extractCoordinates(imageString);
            
            // Extract timestamp
            String timestamp = extractTimestamp(imageString);
            
            return ImageMetadata.builder()
                .securityToken(token)
                .latitude(coordParts[0])
                .longitude(coordParts[1])
                .timestamp(timestamp)
                .imageSize(image.getSize())
                .format(image.getContentType())
                .build();
                
        } catch (Exception e) {
            log.error("Error extracting metadata", e);
            return null;
        }
    }

    /**
     * Validate image metadata against provided coordinates
     */
    private ValidationResult validateImageMetadata(ImageMetadata metadata, double expectedLat, double expectedLng) {
        if (metadata == null) {
            return ValidationResult.builder()
                .valid(false)
                .errorMessage("Unable to extract image metadata.")
                .build();
        }

        // Check coordinates match (within reasonable tolerance)
        double latDiff = Math.abs(Double.parseDouble(metadata.getLatitude()) - expectedLat);
        double lngDiff = Math.abs(Double.parseDouble(metadata.getLongitude()) - expectedLng);
        
        if (latDiff > 0.0001 || lngDiff > 0.0001) { // Very small tolerance
            return ValidationResult.builder()
                .valid(false)
                .errorMessage("Coordinates in image don't match scan location. Possible photo manipulation.")
                .build();
        }

        // Check timestamp is recent (within 5 minutes)
        try {
            long imageTime = Long.parseLong(metadata.getTimestamp());
            long currentTime = System.currentTimeMillis();
            long timeDiff = Math.abs(currentTime - imageTime);
            
            if (timeDiff > 5 * 60 * 1000) { // 5 minutes
                return ValidationResult.builder()
                    .valid(false)
                    .errorMessage("Image timestamp is too old. Real-time capture required.")
                    .build();
            }
        } catch (Exception e) {
            return ValidationResult.builder()
                .valid(false)
                .errorMessage("Invalid timestamp in image metadata.")
                .build();
        }

        return ValidationResult.builder().valid(true).build();
    }

    private String extractSecurityToken(String imageString) {
        try {
            int tokenIndex = imageString.indexOf("SECURITY TOKEN:");
            if (tokenIndex != -1) {
                String tokenLine = imageString.substring(tokenIndex, tokenIndex + 50);
                return tokenLine.split(":")[1].trim();
            }
        } catch (Exception e) {
            log.error("Error extracting security token", e);
        }
        return null;
    }

    private String[] extractCoordinates(String imageString) {
        try {
            int coordIndex = imageString.indexOf("LAT:");
            if (coordIndex != -1) {
                String coordLine = imageString.substring(coordIndex, coordIndex + 50);
                String[] parts = coordLine.split("\\|");
                if (parts.length >= 2) {
                    String lat = parts[0].split(":")[1].trim().replace("°", "");
                    String lng = parts[1].split(":")[1].trim().replace("°", "");
                    return new String[]{lat, lng};
                }
            }
        } catch (Exception e) {
            log.error("Error extracting coordinates", e);
        }
        return new String[]{"0", "0"};
    }

    private String extractTimestamp(String imageString) {
        try {
            // This would need more sophisticated parsing in production
            return String.valueOf(System.currentTimeMillis());
        } catch (Exception e) {
            log.error("Error extracting timestamp", e);
            return null;
        }
    }

    @Data
    @Builder
    public static class ImageMetadata {
        private String securityToken;
        private String latitude;
        private String longitude;
        private String timestamp;
        private long imageSize;
        private String format;
    }
}
