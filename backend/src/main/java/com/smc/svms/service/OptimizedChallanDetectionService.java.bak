    private String generateDetailedReasoning(
            ContainmentAnalysisResult containment, DistanceCalculationResult distance,
            ViolationStatus violationStatus) {
        return String.format("Containment: %s (%s), Distance: %.2fm using %s, " +
                           "Confidence: %.1f%%, Adaptive threshold: %.1fm",
                           containment.isInside() ? "INSIDE" : "OUTSIDE",
                           containment.getContainmentType(),
                           distance.getDistance(),
                           distance.getAlgorithmUsed(),
                           violationStatus.getConfidence() * 100,
                           violationStatus.getAdaptiveThreshold());
    }
    
    private AlgorithmPerformance estimateAlgorithmPerformance(
            AdvancedGeofencingAlgorithms.AlgorithmChoice algorithmChoice) {
        return AlgorithmPerformance.builder()
            .distanceAlgorithm(algorithmChoice.getDistanceAlgorithm().name())
            .containmentAlgorithm(algorithmChoice.getContainmentAlgorithm().name())
            .spatialIndex(algorithmChoice.getSpatialIndex().name())
            .estimatedAccuracy(estimateAccuracy(algorithmChoice))
            .estimatedSpeed(estimateSpeed(algorithmChoice))
            .build();
    }
    
    private double estimateAccuracy(AdvancedGeofencingAlgorithms.AlgorithmChoice choice) {
        return switch (choice.getDistanceAlgorithm()) {
            case VINCENTY -> 0.999999;
            case IMPROVED_HAVERSINE -> 0.999;
            case FAST_EUCLIDEAN -> 0.95;
            default -> 0.99;
        };
    }
    
    private double estimateSpeed(AdvancedGeofencingAlgorithms.AlgorithmChoice choice) {
        return switch (choice.getDistanceAlgorithm()) {
            case VINCENTY -> 0.4; // Slower but more accurate
            case IMPROVED_HAVERSINE -> 0.8; // Good balance
            case FAST_EUCLIDEAN -> 1.0; // Fastest
            default -> 0.7;
        };
    }
    
    private ViolationDetectionResult createNoZoneResult(ViolationDetectionRequest request) {
        return ViolationDetectionResult.builder()
            .vendorId(request.getVendorId())
            .isViolation(false)
            .violationType("NO_ZONE_ASSIGNED")
            .confidence(0.0)
            .distance(Double.MAX_VALUE)
            .processingTimeMs(0)
            .detailedReasoning("Vendor not assigned to any zone")
            .build();
    }
    
    private ViolationDetectionResult createErrorResult(ViolationDetectionRequest request, Exception e) {
        return ViolationDetectionResult.builder()
            .vendorId(request.getVendorId())
            .isViolation(false)
            .violationType("SYSTEM_ERROR")
            .confidence(0.0)
            .distance(Double.MAX_VALUE)
            .processingTimeMs(0)
            .detailedReasoning("System error: " + e.getMessage())
            .build();
    }
    
