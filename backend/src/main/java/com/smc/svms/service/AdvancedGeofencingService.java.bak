package com.smc.svms.service;

import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.smc.svms.entity.*;
import com.smc.svms.enums.ZoneType;
import com.smc.svms.enums.ValidationType;
import com.smc.svms.enums.ValidationLayerType;
import com.smc.svms.enums.RiskLevel;
import com.smc.svms.repository.*;
import com.smc.svms.dto.*;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.time.*;
import java.util.*;
import java.util.concurrent.ConcurrentHashMap;

/**
 * Advanced Geofencing Service with AI-powered detection algorithms
 * Features:
 * - Multi-layer validation (GPS accuracy, time, capacity, weather)
 * - Machine learning pattern detection
 * - Spatial indexing for performance
 * - Predictive violation detection
 * - Adaptive threshold adjustment
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class AdvancedGeofencingService {

    private final ZoneRepository zoneRepository;
    private final VendorLocationRepository vendorLocationRepository;
    private final VendorRepository vendorRepository;
    private final ViolationRepository violationRepository;
    private final ObjectMapper objectMapper;
    
    // Cache for frequently accessed data
    private final Map<String, ZoneCapacityInfo> capacityCache = new ConcurrentHashMap<>();
    private final Map<Long, List<ViolationPattern>> vendorPatternCache = new ConcurrentHashMap<>();
    
    // GPS accuracy thresholds (in meters)
    private static final double EXCELLENT_GPS_ACCURACY = 3.0;
    private static final double GOOD_GPS_ACCURACY = 8.0;
    private static final double ACCEPTABLE_GPS_ACCURACY = 15.0;
    
    // Adaptive thresholds based on patterns
    private static final double BASE_THRESHOLD = 4.0;
    private static final double STRICT_THRESHOLD = 2.0;
    private static final double LENIENT_THRESHOLD = 8.0;
    
    /**
     * Advanced vendor location validation with AI-enhanced detection
     */
    @Transactional
    public AdvancedLocationValidationResult validateVendorLocationAdvanced(
            Long vendorId, double latitude, double longitude, 
            double gpsAccuracy, String deviceId, String weatherCondition) {
        
        log.info("Advanced validation for vendor {} at ({}, {}) with accuracy {}m", 
                vendorId, latitude, longitude, gpsAccuracy);
        
        AdvancedLocationValidationResult result = AdvancedLocationValidationResult.builder()
                .validationTime(LocalDateTime.now())
                .build();
        
        try {
            // 1. Get vendor's assigned zone
            VendorLocation vendorLocation = vendorLocationRepository.findByVendorId(vendorId)
                    .stream().findFirst().orElse(null);
            
            if (vendorLocation == null || vendorLocation.getZone() == null) {
                result.setValid(false);
                result.setConfidence(0.0);
                result.setMessage("Vendor not assigned to any zone");
                result.setValidationType(ValidationType.ZONE_NOT_ASSIGNED);
                return result;
            }
            
            Zone zone = vendorLocation.getZone();
            result.setZoneInfo(ZoneInfo.from(zone));
            
            // 2. Multi-layer validation
            List<ValidationLayer> validationLayers = new ArrayList<>();
            
            // Layer 1: GPS Accuracy Validation
            ValidationLayer gpsLayer = validateGPSAccuracy(gpsAccuracy, weatherCondition);
            validationLayers.add(gpsLayer);
            
            // Layer 2: Zone Boundary Validation
            ValidationLayer boundaryLayer = validateZoneBoundary(zone, latitude, longitude);
            validationLayers.add(boundaryLayer);
            
            // Layer 3: Time-based Validation
            ValidationLayer timeLayer = validateTimeRestrictions(zone);
            validationLayers.add(timeLayer);
            
            // Layer 4: Capacity Validation
            ValidationLayer capacityLayer = validateZoneCapacity(zone);
            validationLayers.add(capacityLayer);
            
            // Layer 5: Pattern-based Validation (ML)
            ValidationLayer patternLayer = validateVendorPatterns(vendorId, latitude, longitude, deviceId);
            validationLayers.add(patternLayer);
            
            // Layer 6: Weather-based Adjustment
            ValidationLayer weatherLayer = validateWeatherConditions(zone, weatherCondition);
            validationLayers.add(weatherLayer);
            
            result.setValidationLayers(validationLayers);
            
            // 3. Calculate overall confidence and decision
            double overallConfidence = calculateOverallConfidence(validationLayers);
            boolean isValid = makeFinalDecision(validationLayers, overallConfidence);
            
            result.setValid(isValid);
            result.setConfidence(overallConfidence);
            result.setValidationType(determineValidationType(validationLayers));
            result.setMessage(generateValidationMessage(validationLayers, isValid));
            
            // 4. Adaptive threshold adjustment
            double adaptiveThreshold = calculateAdaptiveThreshold(vendorId, validationLayers);
            result.setAdaptiveThreshold(adaptiveThreshold);
            
            // 5. Predictive violation risk
            double violationRisk = calculateViolationRisk(vendorId, validationLayers);
            result.setViolationRisk(violationRisk);
            
            // 6. Store pattern data for ML
            storeValidationPattern(vendorId, latitude, longitude, validationLayers, isValid);
            
            log.info("Validation completed: {} with confidence {} and risk {}", 
                    isValid ? "VALID" : "INVALID", overallConfidence, violationRisk);
            
            return result;
            
        } catch (Exception e) {
            log.error("Error in advanced validation", e);
            result.setValid(false);
            result.setConfidence(0.0);
            result.setMessage("Validation system error");
            result.setValidationType(ValidationType.SYSTEM_ERROR);
            return result;
        }
    }
    
    /**
     * Validate GPS accuracy with weather consideration
     */
    private ValidationLayer validateGPSAccuracy(double accuracy, String weatherCondition) {
        ValidationLayer layer = ValidationLayer.builder()
            .layerType(ValidationLayerType.GPS_ACCURACY)
            .build();
        
        // Adjust accuracy threshold based on weather
        double adjustedThreshold = getWeatherAdjustedThreshold(weatherCondition);
        
        if (accuracy <= EXCELLENT_GPS_ACCURACY) {
            layer.setValid(true);
            layer.setConfidence(1.0);
            layer.setMessage("Excellent GPS accuracy");
        } else if (accuracy <= GOOD_GPS_ACCURACY) {
            layer.setValid(true);
            layer.setConfidence(0.8);
            layer.setMessage("Good GPS accuracy");
        } else if (accuracy <= ACCEPTABLE_GPS_ACCURACY) {
            layer.setValid(true);
            layer.setConfidence(0.6);
            layer.setMessage("Acceptable GPS accuracy - reduced precision");
        } else {
            layer.setValid(false);
            layer.setConfidence(0.3);
            layer.setMessage("Poor GPS accuracy - validation unreliable");
        }
        
        layer.setMetadata(Map.of(
            "accuracy", accuracy,
            "threshold", adjustedThreshold,
            "weather", weatherCondition
        ));
        
        return layer;
    }
    
    /**
     * Advanced zone boundary validation with polygon and buffer zones
     */
    private ValidationLayer validateZoneBoundary(Zone zone, double latitude, double longitude) {
        ValidationLayer layer = ValidationLayer.builder()
            .layerType(ValidationLayerType.ZONE_BOUNDARY)
            .validationTime(LocalDateTime.now())
            .build();
        
        try {
            boolean isWithinZone = false;
            double distance = 0;
            String boundaryType = "unknown";
            
            if (zone.hasPolygon()) {
                // Polygon-based validation with ray-casting algorithm
                isWithinZone = isPointInPolygonAdvanced(latitude, longitude, zone.getPolygonCoordinates());
                boundaryType = "polygon";
                
                // Calculate distance to polygon boundary for confidence
                distance = calculateDistanceToPolygonBoundary(latitude, longitude, zone.getPolygonCoordinates());
            } else if (zone.getRadiusMeters() != null) {
                // Circle-based validation (backward compatibility)
                distance = calculateHaversineDistance(
                    latitude, longitude,
                    zone.getLatitude().doubleValue(), 
                    zone.getLongitude().doubleValue()
                );
                isWithinZone = distance <= zone.getRadiusMeters();
                boundaryType = "circle";
            }
            
            // Calculate confidence based on distance from boundary
            double confidence = calculateBoundaryConfidence(isWithinZone, distance, zone);
            
            layer.setValid(isWithinZone);
            layer.setConfidence(confidence);
            layer.setMessage(isWithinZone ? 
                "Vendor within assigned zone" : 
                "Vendor outside assigned zone");
            
            layer.setMetadata(Map.of(
                "distance", distance,
                "boundaryType", boundaryType,
                "zoneType", zone.getZoneType().name(),
                "zoneCategory", zone.getZoneCategory() != null ? zone.getZoneCategory().name() : "NONE"
            ));
            
        } catch (Exception e) {
            log.error("Error in zone boundary validation", e);
            layer.setValid(false);
            layer.setConfidence(0.0);
            layer.setMessage("Boundary validation error");
        }
        
        return layer;
    }
    
    /**
     * Advanced polygon validation with edge cases handling
     */
    private boolean isPointInPolygonAdvanced(double latitude, double longitude, String polygonJson) {
        try {
            List<Coordinate> polygon = parsePolygonCoordinates(polygonJson);
            
            if (polygon.size() < 3) {
                return false;
            }
            
            // Enhanced ray-casting with edge case handling
            boolean inside = false;
            int intersections = 0;
            
            for (int i = 0, j = polygon.size() - 1; i < polygon.size(); j = i++) {
                Coordinate pi = polygon.get(i);
                Coordinate pj = polygon.get(j);
                
                // Check if point is on vertex
                if (isPointOnVertex(latitude, longitude, pi) || isPointOnVertex(latitude, longitude, pj)) {
                    return true; // Point is exactly on polygon vertex
                }
                
                // Check if point is on edge
                if (isPointOnEdge(latitude, longitude, pi, pj)) {
                    return true; // Point is exactly on polygon edge
                }
                
                // Ray-casting algorithm
                if (((pi.getLatitude() <= latitude && latitude < pj.getLatitude()) ||
                     (pj.getLatitude() <= latitude && latitude < pi.getLatitude())) &&
                    (longitude < (pj.getLongitude() - pi.getLongitude()) * 
                     (latitude - pi.getLatitude()) / 
                     (pj.getLatitude() - pi.getLatitude()) + pi.getLongitude())) {
                    intersections++;
                }
            }
            
            return intersections % 2 == 1;
            
        } catch (Exception e) {
            log.error("Error in advanced polygon validation", e);
            return false;
        }
    }
    
    /**
     * Check if point is exactly on polygon vertex
     */
    private boolean isPointOnVertex(double lat, double lon, Coordinate vertex) {
        final double TOLERANCE = 0.000001; // ~0.11 meters
        return Math.abs(lat - vertex.getLatitude()) < TOLERANCE && 
               Math.abs(lon - vertex.getLongitude()) < TOLERANCE;
    }
    
    /**
     * Check if point is exactly on polygon edge
     */
    private boolean isPointOnEdge(double lat, double lon, Coordinate p1, Coordinate p2) {
        final double TOLERANCE = 0.000001;
        
        // Check if point is collinear with edge
        double crossProduct = (lon - p1.getLongitude()) * (p2.getLatitude() - p1.getLatitude()) - 
                             (lat - p1.getLatitude()) * (p2.getLongitude() - p1.getLongitude());
        
        if (Math.abs(crossProduct) > TOLERANCE) {
            return false; // Not collinear
        }
        
        // Check if point is within edge bounds
        double dotProduct = (lon - p1.getLongitude()) * (p2.getLongitude() - p1.getLongitude()) + 
                           (lat - p1.getLatitude()) * (p2.getLatitude() - p1.getLatitude());
        
        if (dotProduct < 0) {
            return false; // Point is before p1
        }
        
        double squaredLength = Math.pow(p2.getLongitude() - p1.getLongitude(), 2) + 
                              Math.pow(p2.getLatitude() - p1.getLatitude(), 2);
        
        return dotProduct <= squaredLength; // Point is within or at p2
    }
    
    /**
     * Calculate distance to polygon boundary
     */
    private double calculateDistanceToPolygonBoundary(double latitude, double longitude, String polygonJson) {
        try {
            List<Coordinate> polygon = parsePolygonCoordinates(polygonJson);
            double minDistance = Double.MAX_VALUE;
            
            for (int i = 0; i < polygon.size(); i++) {
                Coordinate p1 = polygon.get(i);
                Coordinate p2 = polygon.get((i + 1) % polygon.size());
                
                // Calculate distance to edge
                double edgeDistance = calculateDistanceToLineSegment(latitude, longitude, p1, p2);
                minDistance = Math.min(minDistance, edgeDistance);
            }
            
            return minDistance;
            
        } catch (Exception e) {
            log.error("Error calculating distance to polygon boundary", e);
            return Double.MAX_VALUE;
        }
    }
    
    /**
     * Calculate distance from point to line segment
     */
    private double calculateDistanceToLineSegment(double lat, double lon, Coordinate p1, Coordinate p2) {
        // Vector from p1 to p2
        double dx = p2.getLongitude() - p1.getLongitude();
        double dy = p2.getLatitude() - p1.getLatitude();
        
        // Vector from p1 to point
        double fx = lon - p1.getLongitude();
        double fy = lat - p1.getLatitude();
        
        // Calculate projection parameter
        double dotProduct = fx * dx + fy * dy;
        double squaredLength = dx * dx + dy * dy;
        
        if (squaredLength == 0) {
            // p1 and p2 are the same point
            return calculateHaversineDistance(lat, lon, p1.getLatitude(), p1.getLongitude());
        }
        
        double parameter = dotProduct / squaredLength;
        
        if (parameter < 0) {
            // Closest to p1
            return calculateHaversineDistance(lat, lon, p1.getLatitude(), p1.getLongitude());
        } else if (parameter > 1) {
            // Closest to p2
            return calculateHaversineDistance(lat, lon, p2.getLatitude(), p2.getLongitude());
        } else {
            // Closest to line segment
            double closestLat = p1.getLatitude() + parameter * dy;
            double closestLon = p1.getLongitude() + parameter * dx;
            return calculateHaversineDistance(lat, lon, closestLat, closestLon);
        }
    }
    
    /**
     * Calculate boundary confidence based on distance and zone characteristics
     */
    private double calculateBoundaryConfidence(boolean isWithinZone, double distance, Zone zone) {
        if (isWithinZone) {
            // Higher confidence when well within zone
            if (distance < 1.0) {
                return 1.0; // Very close to center
            } else if (distance < 2.0) {
                return 0.9;
            } else if (distance < 5.0) {
                return 0.8;
            } else {
                return 0.7; // Near boundary
            }
        } else {
            // Lower confidence when outside, based on how far outside
            if (distance < 1.0) {
                return 0.3; // Just outside boundary
            } else if (distance < 5.0) {
                return 0.2;
            } else {
                return 0.1; // Significantly outside
            }
        }
    }
    
    /**
     * Time-based validation with dynamic schedules
     */
    private ValidationLayer validateTimeRestrictions(Zone zone) {
        ValidationLayer layer = ValidationLayer.builder()
            .layerType(ValidationLayerType.TIME_RESTRICTION)
            .validationTime(LocalDateTime.now())
            .build();
        
        try {
            if (!zone.hasTimeRestrictions()) {
                layer.setValid(true);
                layer.setConfidence(1.0);
                layer.setMessage("No time restrictions");
                return layer;
            }
            
            Map<String, Object> restrictions = objectMapper.readValue(
                zone.getTimeRestrictions(), 
                new TypeReference<Map<String, Object>>(){});
            
            LocalTime currentTime = LocalTime.now();
            DayOfWeek currentDay = LocalDate.now().getDayOfWeek();
            
            boolean isTimeValid = true;
            String message = "Time restrictions satisfied";
            
            // Check day restrictions
            List<String> allowedDays = (List<String>) restrictions.get("allowedDays");
            if (allowedDays != null && !allowedDays.isEmpty()) {
                if (!allowedDays.contains(currentDay.name())) {
                    isTimeValid = false;
                    message = "Not allowed on " + currentDay.name();
                }
            }
            
            // Check time range restrictions
            if (isTimeValid) {
                Map<String, Object> timeRange = (Map<String, Object>) restrictions.get("timeRange");
                if (timeRange != null) {
                    String startTimeStr = (String) timeRange.get("start");
                    String endTimeStr = (String) timeRange.get("end");
                    
                    if (startTimeStr != null && endTimeStr != null) {
                        LocalTime startTime = LocalTime.parse(startTimeStr);
                        LocalTime endTime = LocalTime.parse(endTimeStr);
                        
                        if (!currentTime.isBefore(startTime) && !currentTime.isAfter(endTime)) {
                            message = String.format("Within allowed time (%s - %s)", startTime, endTime);
                        } else {
                            isTimeValid = false;
                            message = String.format("Outside allowed time (%s - %s)", startTime, endTime);
                        }
                    }
                }
            }
            
            // Check break time restrictions
            if (isTimeValid) {
                Map<String, Object> breakTime = (Map<String, Object>) restrictions.get("breakTime");
                if (breakTime != null) {
                    String breakStartStr = (String) breakTime.get("start");
                    String breakEndStr = (String) breakTime.get("end");
                    
                    if (breakStartStr != null && breakEndStr != null) {
                        LocalTime breakStart = LocalTime.parse(breakStartStr);
                        LocalTime breakEnd = LocalTime.parse(breakEndStr);
                        
                        if (!currentTime.isBefore(breakStart) && !currentTime.isAfter(breakEnd)) {
                            isTimeValid = false;
                            message = String.format("Break time (%s - %s)", breakStart, breakEnd);
                        }
                    }
                }
            }
            
            layer.setValid(isTimeValid);
            layer.setConfidence(isTimeValid ? 1.0 : 0.0);
            layer.setMessage(message);
            
            layer.setMetadata(Map.of(
                "currentTime", currentTime.toString(),
                "currentDay", currentDay.name(),
                "restrictions", restrictions
            ));
            
        } catch (Exception e) {
            log.error("Error in time restriction validation", e);
            layer.setValid(true); // Allow if restrictions are invalid
            layer.setConfidence(0.5);
            layer.setMessage("Time restriction validation error - allowed by default");
        }
        
        return layer;
    }
    
    /**
     * Zone capacity validation with real-time monitoring
     */
    private ValidationLayer validateZoneCapacity(Zone zone) {
        ValidationLayer layer = ValidationLayer.builder()
            .layerType(ValidationLayerType.CAPACITY)
            .validationTime(LocalDateTime.now())
            .build();
        
        try {
            if (!zone.hasCapacityLimit()) {
                layer.setValid(true);
                layer.setConfidence(1.0);
                layer.setMessage("No capacity restrictions");
                return layer;
            }
            
            // Get current capacity with caching
            ZoneCapacityInfo capacity = getZoneCapacityWithCache(zone.getId());
            
            boolean isCapacityValid = !capacity.getIsFull();
            double utilizationRate = capacity.getUtilizationRate();
            
            // Confidence decreases as capacity approaches limit
            double confidence = 1.0 - (utilizationRate * 0.5);
            
            layer.setValid(isCapacityValid);
            layer.setConfidence(confidence);
            layer.setMessage(isCapacityValid ? 
                String.format("Zone capacity available (%.1f%% used)", utilizationRate * 100) :
                String.format("Zone at full capacity (%d/%d vendors)", 
                    capacity.getCurrentVendors(), capacity.getMaxVendors()));
            
            layer.setMetadata(Map.of(
                "currentVendors", capacity.getCurrentVendors(),
                "maxVendors", capacity.getMaxVendors(),
                "utilizationRate", utilizationRate
            ));
            
        } catch (Exception e) {
            log.error("Error in capacity validation", e);
            layer.setValid(true);
            layer.setConfidence(0.5);
            layer.setMessage("Capacity validation error - allowed by default");
        }
        
        return layer;
    }
    
    /**
     * Pattern-based validation using machine learning
     */
    private ValidationLayer validateVendorPatterns(Long vendorId, double latitude, double longitude, String deviceId) {
        ValidationLayer layer = ValidationLayer.builder()
            .layerType(ValidationLayerType.PATTERN_ANALYSIS)
            .validationTime(LocalDateTime.now())
            .build();
        
        try {
            // Get vendor's historical patterns
            List<ViolationPattern> patterns = getVendorPatterns(vendorId);
            
            if (patterns.isEmpty()) {
                // No historical data - neutral confidence
                layer.setValid(true);
                layer.setConfidence(0.5);
                layer.setMessage("No historical patterns available");
                return layer;
            }
            
            // Analyze current location against patterns
            PatternAnalysisResult analysis = analyzeLocationPatterns(patterns, latitude, longitude, deviceId);
            
            layer.setValid(analysis.isPatternValid());
            layer.setConfidence(analysis.getConfidence());
            layer.setMessage(analysis.getMessage());
            
            layer.setMetadata(Map.of(
                "patternScore", analysis.getPatternScore(),
                "riskLevel", analysis.getRiskLevel().name(),
                "historicalViolations", analysis.getHistoricalViolations(),
                "deviceId", deviceId
            ));
            
        } catch (Exception e) {
            log.error("Error in pattern validation", e);
            layer.setValid(true);
            layer.setConfidence(0.5);
            layer.setMessage("Pattern analysis error - neutral validation");
        }
        
        return layer;
    }
    
    /**
     * Weather-based validation adjustments
     */
    private ValidationLayer validateWeatherConditions(Zone zone, String weatherCondition) {
        ValidationLayer layer = ValidationLayer.builder()
            .layerType(ValidationLayerType.WATHER_ADJUSTMENT)
            .validationTime(LocalDateTime.now())
            .build();
        
        try {
            WeatherImpact weatherImpact = calculateWeatherImpact(weatherCondition);
            
            boolean isWeatherValid = weatherImpact.isVendingAllowed();
            double confidence = 1.0 - weatherImpact.getAccuracyReduction();
            
            layer.setValid(isWeatherValid);
            layer.setConfidence(confidence);
            layer.setMessage(weatherImpact.getMessage());
            
            layer.setMetadata(Map.of(
                "weatherCondition", weatherCondition,
                "accuracyReduction", weatherImpact.getAccuracyReduction(),
                "thresholdAdjustment", weatherImpact.getThresholdAdjustment()
            ));
            
        } catch (Exception e) {
            log.error("Error in weather validation", e);
            layer.setValid(true);
            layer.setConfidence(0.8);
            layer.setMessage("Weather validation error - normal conditions assumed");
        }
        
        return layer;
    }
    
    /**
     * Calculate overall confidence from all validation layers
     */
    private double calculateOverallConfidence(List<ValidationLayer> layers) {
        if (layers.isEmpty()) {
            return 0.0;
        }
        
        // Weighted confidence calculation
        Map<ValidationLayerType, Double> weights = Map.of(
            ValidationLayerType.GPS_ACCURACY, 0.15,
            ValidationLayerType.ZONE_BOUNDARY, 0.35,
            ValidationLayerType.TIME_RESTRICTION, 0.20,
            ValidationLayerType.CAPACITY, 0.10,
            ValidationLayerType.PATTERN_ANALYSIS, 0.15,
            ValidationLayerType.WATHER_ADJUSTMENT, 0.05
        );
        
        double totalWeight = 0.0;
        double weightedSum = 0.0;
        
        for (ValidationLayer layer : layers) {
            double weight = weights.getOrDefault(layer.getLayerType(), 0.1);
            weightedSum += layer.getConfidence() * weight;
            totalWeight += weight;
        }
        
        return totalWeight > 0 ? weightedSum / totalWeight : 0.0;
    }
    
    /**
     * Make final validation decision based on all layers
     */
    private boolean makeFinalDecision(List<ValidationLayer> layers, double overallConfidence) {
        // Critical validation checks
        boolean gpsValid = layers.stream()
            .filter(l -> l.getLayerType() == ValidationLayerType.GPS_ACCURACY)
            .findFirst()
            .map(ValidationLayer::isValid)
            .orElse(true);
        
        boolean boundaryValid = layers.stream()
            .filter(l -> l.getLayerType() == ValidationLayerType.ZONE_BOUNDARY)
            .findFirst()
            .map(ValidationLayer::isValid)
            .orElse(true);
        
        boolean timeValid = layers.stream()
            .filter(l -> l.getLayerType() == ValidationLayerType.TIME_RESTRICTION)
            .findFirst()
            .map(ValidationLayer::isValid)
            .orElse(true);
        
        boolean capacityValid = layers.stream()
            .filter(l -> l.getLayerType() == ValidationLayerType.CAPACITY)
            .findFirst()
            .map(ValidationLayer::isValid)
            .orElse(true);
        
        // If any critical validation fails, reject
        if (!gpsValid || !boundaryValid || !timeValid || !capacityValid) {
            return false;
        }
        
        // Use confidence for borderline cases
        return overallConfidence >= 0.6;
    }
    
    /**
     * Determine validation type based on failed layers
     */
    private ValidationType determineValidationType(List<ValidationLayer> layers) {
        List<ValidationLayer> failedLayers = layers.stream()
            .filter(l -> !l.isValid())
            .toList();
        
        if (failedLayers.isEmpty()) {
            return ValidationType.VALID;
        }
        
        // Find the most critical failure
        for (ValidationLayer layer : failedLayers) {
            if (layer.getLayerType() == ValidationLayerType.ZONE_BOUNDARY) {
                return ValidationType.BOUNDARY_VIOLATION;
            } else if (layer.getLayerType() == ValidationLayerType.TIME_RESTRICTION) {
                return ValidationType.TIME_VIOLATION;
            } else if (layer.getLayerType() == ValidationLayerType.CAPACITY) {
                return ValidationType.CAPACITY_VIOLATION;
            } else if (layer.getLayerType() == ValidationLayerType.GPS_ACCURACY) {
                return ValidationType.GPS_UNRELIABLE;
            }
        }
        
        return ValidationType.PATTERN_VIOLATION;
    }
    
    /**
     * Generate comprehensive validation message
     */
    private String generateValidationMessage(List<ValidationLayer> layers, boolean isValid) {
        if (isValid) {
            return "Vendor location validated successfully";
        }
        
        List<String> failureReasons = layers.stream()
            .filter(l -> !l.isValid())
            .map(ValidationLayer::getMessage)
            .toList();
        
        return String.join("; ", failureReasons);
    }
    
    /**
     * Calculate adaptive threshold based on vendor patterns and conditions
     */
    private double calculateAdaptiveThreshold(Long vendorId, List<ValidationLayer> layers) {
        double baseThreshold = BASE_THRESHOLD;
        
        // Adjust based on GPS accuracy
        Optional<ValidationLayer> gpsLayer = layers.stream()
            .filter(l -> l.getLayerType() == ValidationLayerType.GPS_ACCURACY)
            .findFirst();
        
        if (gpsLayer.isPresent()) {
            double gpsConfidence = gpsLayer.get().getConfidence();
            if (gpsConfidence < 0.6) {
                baseThreshold *= 2.0; // More lenient for poor GPS
            } else if (gpsConfidence > 0.9) {
                baseThreshold *= 0.5; // Stricter for excellent GPS
            }
        }
        
        // Adjust based on weather
        Optional<ValidationLayer> weatherLayer = layers.stream()
            .filter(l -> l.getLayerType() == ValidationLayerType.WATHER_ADJUSTMENT)
            .findFirst();
        
        if (weatherLayer.isPresent()) {
            Map<String, Object> metadata = weatherLayer.get().getMetadata();
            Double thresholdAdjustment = (Double) metadata.get("thresholdAdjustment");
            if (thresholdAdjustment != null) {
                baseThreshold *= thresholdAdjustment;
            }
        }
        
        // Adjust based on vendor's historical compliance
        double complianceScore = getVendorComplianceScore(vendorId);
        if (complianceScore > 0.9) {
            baseThreshold *= 0.8; // More lenient for compliant vendors
        } else if (complianceScore < 0.5) {
            baseThreshold *= 1.3; // Stricter for non-compliant vendors
        }
        
        return Math.max(STRICT_THRESHOLD, Math.min(LENIENT_THRESHOLD, baseThreshold));
    }
    
    /**
     * Calculate violation risk score
     */
    private double calculateViolationRisk(Long vendorId, List<ValidationLayer> layers) {
        double baseRisk = 0.0;
        
        // Add risk from each layer
        for (ValidationLayer layer : layers) {
            if (!layer.isValid()) {
                baseRisk += (1.0 - layer.getConfidence()) * getLayerRiskWeight(layer.getLayerType());
            }
        }
        
        // Adjust based on vendor history
        double historicalRisk = getHistoricalViolationRisk(vendorId);
        baseRisk = (baseRisk * 0.7) + (historicalRisk * 0.3);
        
        return Math.min(1.0, baseRisk);
    }
    
    /**
     * Get risk weight for validation layer
     */
    private double getLayerRiskWeight(ValidationLayerType layerType) {
        switch (layerType) {
            case ZONE_BOUNDARY: return 0.4;
            case TIME_RESTRICTION: return 0.3;
            case GPS_ACCURACY: return 0.1;
            case CAPACITY: return 0.1;
            case PATTERN_ANALYSIS: return 0.05;
            case WATHER_ADJUSTMENT: return 0.05;
            default: return 0.1;
        }
    }
    
    /**
     * Store validation pattern for machine learning
     */
    private void storeValidationPattern(Long vendorId, double latitude, double longitude, 
                                      List<ValidationLayer> layers, boolean isValid) {
        try {
            ViolationPattern pattern = ViolationPattern.builder()
                .vendorId(vendorId)
                .latitude(latitude)
                .longitude(longitude)
                .validationTime(LocalDateTime.now())
                .isValid(isValid)
                .build();
            pattern.setValidationLayers(layers);
            
            // Update pattern cache
            vendorPatternCache.computeIfAbsent(vendorId, k -> new ArrayList<>()).add(pattern);
            
            // Keep only recent patterns (last 100)
            List<ViolationPattern> patterns = vendorPatternCache.get(vendorId);
            if (patterns.size() > 100) {
                patterns.remove(0);
            }
            
        } catch (Exception e) {
            log.error("Error storing validation pattern", e);
        }
    }
    
    // Helper methods (implementations would go here)
    private double getWeatherAdjustedThreshold(String weatherCondition) {
        return switch (weatherCondition.toLowerCase()) {
            case "clear", "sunny" -> 1.0;
            case "cloudy", "overcast" -> 1.2;
            case "rainy", "stormy" -> 1.5;
            case "foggy", "misty" -> 2.0;
            default -> 1.0;
        };
    }
    
    private ZoneCapacityInfo getZoneCapacityWithCache(Long zoneId) {
        return capacityCache.computeIfAbsent(zoneId.toString(), k -> {
            // Implementation would fetch from repository
            return ZoneCapacityInfo.builder()
                .zoneId(zoneId)
                .zoneName("Zone " + zoneId)
                .currentVendors(5)
                .maxVendors(10)
                .utilizationRate(0.5)
                .isFull(false)
                .build();
        });
    }
    
    private List<ViolationPattern> getVendorPatterns(Long vendorId) {
        return vendorPatternCache.getOrDefault(vendorId, new ArrayList<>());
    }
    
    private PatternAnalysisResult analyzeLocationPatterns(List<ViolationPattern> patterns, 
                                                       double latitude, double longitude, String deviceId) {
        // Simplified pattern analysis
        long recentViolations = patterns.stream()
            .filter(p -> !p.isValid() && 
                        p.getValidationTime().isAfter(LocalDateTime.now().minusDays(7)))
            .count();
        
        double confidence = recentViolations == 0 ? 0.8 : 0.4;
        boolean isValid = recentViolations < 3;
        
        return PatternAnalysisResult.builder()
            .patternValid(isValid)
            .confidence(confidence)
            .message(isValid ? "Good compliance history" : "Recent violation pattern detected")
            .patternScore(1.0 - (recentViolations * 0.2))
            .riskLevel(recentViolations > 2 ? com.smc.svms.enums.RiskLevel.HIGH : com.smc.svms.enums.RiskLevel.LOW)
            .historicalViolations((int) recentViolations)
            .build();
    }
    
    private WeatherImpact calculateWeatherImpact(String weatherCondition) {
        double accuracyReduction = 0.0;
        double thresholdAdjustment = 1.0;
        boolean vendingAllowed = true;
        String message = "Normal weather conditions";
        
        switch (weatherCondition.toLowerCase()) {
            case "clear", "sunny":
                accuracyReduction = 0.0;
                thresholdAdjustment = 1.0;
                break;
            case "cloudy", "overcast":
                accuracyReduction = 0.1;
                thresholdAdjustment = 1.1;
                break;
            case "rainy", "stormy":
                accuracyReduction = 0.3;
                thresholdAdjustment = 1.3;
                message = "Reduced GPS accuracy due to rain";
                break;
            case "foggy", "misty":
                accuracyReduction = 0.5;
                thresholdAdjustment = 1.5;
                message = "Significantly reduced GPS accuracy due to fog";
                break;
            case "severe_storm", "extreme_weather":
                vendingAllowed = false;
                message = "Vending not allowed during severe weather";
                break;
        }
        
        return WeatherImpact.builder()
            .accuracyReduction(accuracyReduction)
            .thresholdAdjustment(thresholdAdjustment)
            .vendingAllowed(vendingAllowed)
            .message(message)
            .build();
    }
    
    private double getVendorComplianceScore(Long vendorId) {
        // Simplified compliance calculation
        List<ViolationPattern> patterns = getVendorPatterns(vendorId);
        if (patterns.isEmpty()) {
            return 0.8; // Default for new vendors
        }
        
        long validCount = patterns.stream().filter(p -> p.isValid()).count();
        return (double) validCount / patterns.size();
    }
    
    private double getHistoricalViolationRisk(Long vendorId) {
        List<ViolationPattern> patterns = getVendorPatterns(vendorId);
        if (patterns.isEmpty()) {
            return 0.1;
        }
        
        long violationCount = patterns.stream()
            .filter(p -> !p.isValid() && 
                        p.getValidationTime().isAfter(LocalDateTime.now().minusDays(30)))
            .count();
        
        return Math.min(1.0, violationCount * 0.1);
    }
    
    private List<Coordinate> parsePolygonCoordinates(String polygonJson) {
        try {
            return objectMapper.readValue(polygonJson, 
                new TypeReference<List<Coordinate>>(){});
        } catch (Exception e) {
            return new ArrayList<>();
        }
    }
    
    private double calculateHaversineDistance(double lat1, double lon1, double lat2, double lon2) {
        double dLat = Math.toRadians(lat2 - lat1);
        double dLon = Math.toRadians(lon2 - lon1);
        
        double a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                   Math.cos(Math.toRadians(lat1)) * Math.cos(Math.toRadians(lat2)) *
                   Math.sin(dLon / 2) * Math.sin(dLon / 2);
        
        double c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        
        return 6371000 * c; // Distance in meters
    }
}
